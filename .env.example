# Discord Bot Configuration
DISCORD_TOKEN=paste_your_bot_token_here
CLIENT_ID=paste_your_application_id_here

# Database Configuration
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority

# Bot Owner Configuration
OWNER_ID=your_discord_user_id_here
MAIN_GUILD_ID=your_main_server_id_here

# Dashboard Configuration (Optional)
DASHBOARD_SECRET=your_random_secure_secret_here
PORT=3001
CALLBACK_URL=http://localhost:3001/auth/callback

# Environment
NODE_ENV=production

# Instructions:
# 1. Copy this file to .env
# 2. Replace all placeholder values with your actual credentials
# 3. Never commit the .env file to Git
# 4. For production deployment on Render.com, add these as environment variables in the Render dashboard
