<div class="sidebar animate-mobile fixed inset-y-0 left-0 w-64 bg-white dark:bg-gray-800 shadow-xl border-r border-gray-200 dark:border-gray-700 z-60">
    <div class="flex flex-col h-full">
        <div class="sidebar-header p-6 border-b border-gray-200 dark:border-gray-700 bg-gradient-to-r from-white to-gray-50 dark:from-gray-800 dark:to-gray-900">
            <div class="flex items-center space-x-3 group">
                <img src="/images/logo.png" alt="LR7 Community Bot" class="logo w-10 h-10 rounded-xl shadow-lg transform group-hover:scale-110 transition-all duration-300">
                <div>
                    <h1 class="text-xl font-bold text-gray-800 dark:text-white">
                        LR7 Bot
                    </h1>
                    <p class="text-xs text-gray-500 dark:text-gray-400 font-medium">
                        <%= locale.dashboard.subtitle %>
                    </p>
                </div>
            </div>
            
            <% if (locals.user) { %>
            <div class="mt-4 p-3 bg-gray-100 dark:bg-gray-700 rounded-lg">
                <div class="flex items-center space-x-2">
                    <% if (locals.user.avatar) { %>
                        <img src="https://cdn.discordapp.com/avatars/<%= locals.user.id %>/<%= locals.user.avatar %>.png" alt="<%= locals.user.username %>" class="w-8 h-8 rounded-full">
                    <% } else { %>
                        <div class="w-8 h-8 rounded-full bg-blue-500 flex items-center justify-center text-white font-bold text-sm">
                            <%= locals.user.username.charAt(0).toUpperCase() %>
                        </div>
                    <% } %>
                    <div class="flex-1 min-w-0">
                        <p class="text-sm font-medium text-gray-800 dark:text-white truncate">
                            <%= locals.user.username %>
                        </p>
                    </div>
                </div>
                <a href="/auth/logout" class="mt-2 block text-center text-xs text-red-600 dark:text-red-400 hover:underline">
                    Logout
                </a>
            </div>
            <% } else { %>
            <div class="mt-4">
                <a href="/auth/login" class="block w-full text-center px-4 py-2 bg-blue-500 hover:bg-blue-600 text-white rounded-lg text-sm font-medium transition-colors">
                    Login with Discord
                </a>
            </div>
            <% } %>
        </div>

        <nav class="sidebar-content flex-1 px-4 py-4 overflow-y-auto custom-scrollbar">
            <div class="nav-section mb-6 transform hover:scale-[1.01] transition-transform">
                <h2 class="nav-section-title px-4 text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-3 flex items-center">
                    <i class="fas fa-home mr-2"></i>
                    <%= currentLang === 'ar' ? 'الرئيسية' : 'MAIN' %>
                </h2>
                <div class="nav-links space-y-1">
                    <a href="/" class="nav-link flex items-center px-4 py-3 text-gray-700 dark:text-gray-300 hover:bg-blue-50 dark:hover:bg-gray-700 rounded-xl transition-all duration-300 group <%= path === '/' ? 'active bg-gradient-to-r from-blue-50 to-blue-100 dark:from-blue-900/20 dark:to-blue-900/10 border-r-4 border-blue-500' : '' %>">
                        <i class="fas fa-home w-6 text-gray-400 group-hover:text-blue-500 transform group-hover:scale-110 transition-transform"></i>
                        <span class="ml-2"><%= currentLang === 'ar' ? 'لوحة التحكم' : 'Dashboard' %></span>
                    </a>
                    
                    <a href="/settings" class="nav-link flex items-center px-4 py-3 text-gray-700 dark:text-gray-300 hover:bg-blue-50 dark:hover:bg-gray-700 rounded-xl transition-all duration-300 group <%= path === '/settings' ? 'active bg-gradient-to-r from-blue-50 to-blue-100 dark:from-blue-900/20 dark:to-blue-900/10 border-r-4 border-blue-500' : '' %>">
                        <i class="fas fa-cog w-6 text-gray-400 group-hover:text-blue-500 transform group-hover:scale-110 transition-transform"></i>
                        <span class="ml-2"><%= locale.dashboard.settings?.title || 'Settings' %></span>
                    </a>

                    <a href="/docs" class="nav-link flex items-center px-4 py-3 text-gray-700 dark:text-gray-300 hover:bg-blue-50 dark:hover:bg-gray-700 rounded-xl transition-all duration-300 group <%= path === '/docs' ? 'active bg-gradient-to-r from-blue-50 to-blue-100 dark:from-blue-900/20 dark:to-blue-900/10 border-r-4 border-blue-500' : '' %>">
                        <i class="fas fa-book text-xl group-hover:text-blue-500 <%= path === '/docs' ? 'text-blue-500' : 'text-gray-400' %>"></i>
                        <span class="ml-3"><%= locale.dashboard.navigation.docs %></span>
                    </a>
                </div>
            </div>

            <div class="nav-section mb-6 transform hover:scale-[1.01] transition-transform">
                <h2 class="nav-section-title px-4 text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-3 flex items-center">
                    <i class="fas fa-terminal mr-2"></i>
                    <%= currentLang === 'ar' ? 'الأوامر' : 'COMMANDS' %>
                </h2>
                <div class="nav-links space-y-1">
                    <a href="/commands/general" class="nav-link flex items-center px-4 py-3 text-gray-700 dark:text-gray-300 hover:bg-blue-50 dark:hover:bg-gray-700 rounded-xl transition-all duration-300 group <%= path.startsWith('/commands/general') ? 'active bg-gradient-to-r from-blue-50 to-blue-100 dark:from-blue-900/20 dark:to-blue-900/10 border-r-4 border-blue-500' : '' %>">
                        <i class="fas fa-terminal w-6 text-gray-400 group-hover:text-blue-500 transform group-hover:scale-110 transition-transform"></i>
                        <span class="ml-2"><%= currentLang === 'ar' ? 'الأوامر العامة' : 'General Commands' %></span>
                    </a>
                    <a href="/commands/moderation" class="nav-link flex items-center px-4 py-3 text-gray-700 dark:text-gray-300 hover:bg-blue-50 dark:hover:bg-gray-700 rounded-xl transition-all duration-300 group <%= path.startsWith('/commands/moderation') ? 'active bg-gradient-to-r from-blue-50 to-blue-100 dark:from-blue-900/20 dark:to-blue-900/10 border-r-4 border-blue-500' : '' %>">
                        <i class="fas fa-shield-alt w-6 text-gray-400 group-hover:text-blue-500 transform group-hover:scale-110 transition-transform"></i>
                        <span class="ml-2"><%= currentLang === 'ar' ? 'أوامر الإشراف' : 'Moderation Commands' %></span>
                    </a>
                </div>
            </div>

            <div class="mb-6 transform hover:scale-[1.01] transition-transform">
                <h2 class="px-4 text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-3 flex items-center">
                    <i class="fas fa-flask mr-2"></i>
                    <%= currentLang === 'ar' ? 'متقدم' : 'ADVANCED' %>
                </h2>
                <div class="space-y-1">
                    <% const advancedLinks = [
                        { path: '/aimod', icon: 'fa-brain', name: 'aiModeration' },
                        { path: '/integrations', icon: 'fa-share-alt', name: 'socialIntegration' },
                        { path: '/webhooks', icon: 'fa-link', name: 'webhooks' },
                        { path: '/system', icon: 'fa-server', name: 'system' }
                    ] %>
                    
                    <% advancedLinks.forEach(link => { %>
                        <a href="<%= link.path %>" 
                           class="nav-link flex items-center px-4 py-3 text-gray-700 dark:text-gray-300 hover:bg-blue-50 dark:hover:bg-gray-700 rounded-xl transition-all duration-300 group <%= path === link.path ? 'active bg-gradient-to-r from-blue-50 to-blue-100 dark:from-blue-900/20 dark:to-blue-900/10 border-r-4 border-blue-500' : '' %>">
                            <i class="fas <%= link.icon %> w-6 text-gray-400 group-hover:text-blue-500 transform group-hover:scale-110 transition-transform"></i>
                            <span class="ml-2"><%= locale.dashboard.navigation[link.name] %></span>
                        </a>
                    <% }) %>
                </div>
            </div>

            <div class="mb-6 transform hover:scale-[1.01] transition-transform">
                <h2 class="px-4 text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-3 flex items-center">
                    <i class="fas fa-cog mr-2"></i>
                    <%= currentLang === 'ar' ? 'الإعدادات' : 'CONFIGURATION' %>
                </h2>
                <div class="space-y-1">
                    <% const configLinks = [
                        { path: '/logs', icon: 'fa-history', name: 'logs' },
                        { path: '/tickets', icon: 'fa-ticket-alt', name: 'tickets' },
                        { path: '/rules', icon: 'fa-gavel', name: 'rules' },
                        { path: '/suggestions', icon: 'fa-lightbulb', name: 'suggestions' },
                        { path: '/apply', icon: 'fa-user-plus', name: 'apply' },
                        { path: '/giveaway', icon: 'fa-gift', name: 'giveaway' },
                        { path: '/tempChannels', icon: 'fa-microphone', name: 'tempChannels' },
                        { path: '/autoreply', icon: 'fa-reply', name: 'autoReply' },
                        { path: '/welcome', icon: 'fa-hand-wave', name: 'welcome' },
                        { path: '/selectroles', icon: 'fa-id-badge', name: 'selectRoles' },
                        { path: '/games', icon: 'fa-gamepad', name: 'games' },
                        { path: '/automod', icon: 'fa-robot', name: 'automod' },
                        { path: '/autolines', icon: 'fa-align-left', name: 'autoLines' },
                        { path: '/leveling', icon: 'fa-chart-line', name: 'leveling' },
                        { path: '/economy', icon: 'fa-coins', name: 'economy' },
                        { path: '/verification', icon: 'fa-user-check', name: 'verification' },
                        { path: '/serverlock', icon: 'fa-lock', name: 'serverLock' },
                        { path: '/rolemanagement', icon: 'fa-users-cog', name: 'roleManagement' }
                    ] %>
                    
                    <% configLinks.forEach(link => { %>
                        <a href="<%= link.path %>" 
                           class="nav-link flex items-center px-4 py-3 text-gray-700 dark:text-gray-300 hover:bg-blue-50 dark:hover:bg-gray-700 rounded-xl transition-all duration-300 group <%= path === link.path ? 'active bg-gradient-to-r from-blue-50 to-blue-100 dark:from-blue-900/20 dark:to-blue-900/10 border-r-4 border-blue-500' : '' %>">
                            <i class="fas <%= link.icon %> w-6 text-gray-400 group-hover:text-blue-500 transform group-hover:scale-110 transition-transform"></i>
                            <span class="ml-2"><%= locale.dashboard.navigation[link.name] %></span>
                        </a>
                    <% }) %>
                </div>
            </div>

            <div class="mb-6 transform hover:scale-[1.01] transition-transform">
                <h2 class="px-4 text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-3 flex items-center">
                    <i class="fas fa-shield-alt mr-2"></i>
                    <%= currentLang === 'ar' ? 'إعدادات الحماية' : 'PROTECTION SETTINGS' %>
                </h2>
                <div class="space-y-1">
                    <a href="/protection" class="nav-link flex items-center px-4 py-3 text-gray-700 dark:text-gray-300 hover:bg-blue-50 dark:hover:bg-gray-700 rounded-xl transition-all duration-300 group <%= path === '/protection' ? 'active bg-gradient-to-r from-blue-50 to-blue-100 dark:from-blue-900/20 dark:to-blue-900/10 border-r-4 border-blue-500' : '' %>">
                        <i class="fas fa-shield-alt w-6 text-gray-400 group-hover:text-blue-500 transform group-hover:scale-110 transition-transform"></i>
                        <span class="ml-2"><%= currentLang === 'ar' ? 'إعدادات الحماية' : 'Protection Settings' %></span>
                    </a>
                </div>
            </div>
        </nav>

        <div class="p-4 border-t border-gray-200 dark:border-gray-700 bg-gradient-to-b from-transparent to-gray-50 dark:to-gray-900">
            <div class="flex flex-col space-y-4">
                <div class="flex items-center justify-between bg-white dark:bg-gray-700 p-3 rounded-xl shadow-sm">
                    <div class="flex items-center space-x-2">
                        <div class="h-3 w-3 bg-green-500 rounded-full status-indicator animate-pulse"></div>
                        <span class="text-sm font-medium text-gray-600 dark:text-gray-300">
                            <%= locale.dashboard.status.online %>
                        </span>
                    </div>
                    <button id="themeToggle" class="text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200 transform hover:scale-110 transition-all duration-300 focus:outline-none">
                        <i class="fas fa-moon"></i>
                    </button>
                </div>

                <div class="flex items-center justify-between bg-white dark:bg-gray-700 p-3 rounded-xl shadow-sm">
                    <select id="languageSelect" class="w-full bg-transparent text-gray-600 dark:text-gray-300 text-sm font-medium focus:outline-none cursor-pointer">
                        <option value="en" <%= currentLang === 'en' ? 'selected' : '' %>>
                            🇺🇸 English
                        </option>
                    </select>
                </div>

                <div class="grid grid-cols-4 gap-2 pt-2 border-t border-gray-200 dark:border-gray-700">
                    <% const socialLinks = [
                        { url: 'https://github.com/lr7', icon: 'fa-github', color: 'hover:text-gray-900' },
                        { url: '#', icon: 'fa-youtube', color: 'hover:text-red-600' },
                        { url: '#', icon: 'fa-instagram', color: 'hover:text-pink-600' },
                        { url: '#', icon: 'fa-discord', color: 'hover:text-indigo-600' }
                    ] %>

                    <% socialLinks.forEach(link => { %>
                        <a href="<%= link.url %>" target="_blank" 
                           class="flex items-center justify-center p-2 text-gray-500 dark:text-gray-400 <%= link.color %> transform hover:scale-125 transition-all duration-300 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700">
                            <i class="fab <%= link.icon %>"></i>
                        </a>
                    <% }) %>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.custom-scrollbar::-webkit-scrollbar {
    width: 4px;
}

.custom-scrollbar::-webkit-scrollbar-track {
    background: transparent;
}

.custom-scrollbar::-webkit-scrollbar-thumb {
    background: rgba(99, 102, 241, 0.2);
    border-radius: 2px;
}

.custom-scrollbar::-webkit-scrollbar-thumb:hover {
    background: rgba(99, 102, 241, 0.4);
}

@keyframes status-pulse {
    0% { box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.4); }
    70% { box-shadow: 0 0 0 10px rgba(34, 197, 94, 0); }
    100% { box-shadow: 0 0 0 0 rgba(34, 197, 94, 0); }
}

.status-indicator {
    animation: status-pulse 2s infinite;
}

.nav-link {
    position: relative;
    overflow: hidden;
}

.nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background: #3B82F6;
    transition: width 0.3s ease;
}

.nav-link:hover::after {
    width: 100%;
}

.active.nav-link::after {
    width: 100%;
}
</style>
