<%- contentFor('body') %>

<div class="bg-gradient-to-r from-red-500 to-red-600 text-white rounded-xl shadow-lg mb-6 overflow-hidden animate-fade-in">
    <div class="relative p-6 md:p-8">
        <div class="absolute right-0 top-0 opacity-10">
            <i class="fas fa-lock fa-10x"></i>
        </div>
        <div class="relative z-10">
            <h1 class="text-2xl md:text-3xl lg:text-4xl font-bold mb-2">Server Lock Settings</h1>
            <p class="text-red-100 mb-4 max-w-2xl">
                Manage global lockdowns and maintenance modes for your server.
            </p>
        </div>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-2 space-y-6">
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md p-6 border-l-4 border-red-500">
            <div class="flex items-center justify-between mb-6">
                <div>
                    <h2 class="text-xl font-bold text-gray-800 dark:text-white">Global Lockdown</h2>
                    <p class="text-sm text-gray-500 dark:text-gray-400">Lock the entire server. New members will be blocked or roles restricted.</p>
                </div>
                <label class="relative inline-flex items-center cursor-pointer">
                    <input type="checkbox" id="serverLocked" class="sr-only peer" <%= settings.serverLock?.locked ? 'checked' : '' %>>
                    <div class="w-14 h-7 bg-gray-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-red-300 dark:peer-focus:ring-red-800 rounded-full peer dark:bg-gray-700 peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-0.5 after:left-[4px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-6 after:w-6 after:transition-all dark:border-gray-600 peer-checked:bg-red-600"></div>
                </label>
            </div>

            <div class="flex items-center justify-between mb-6">
                <div>
                    <h2 class="text-xl font-bold text-gray-800 dark:text-white">Maintenance Mode</h2>
                    <p class="text-sm text-gray-500 dark:text-gray-400">Only administrators can interact with the bot and certain channels.</p>
                </div>
                <label class="relative inline-flex items-center cursor-pointer">
                    <input type="checkbox" id="maintenanceMode" class="sr-only peer" <%= settings.serverLock?.maintenance ? 'checked' : '' %>>
                    <div class="w-14 h-7 bg-gray-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-red-300 dark:peer-focus:ring-red-800 rounded-full peer dark:bg-gray-700 peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-0.5 after:left-[4px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-6 after:w-6 after:transition-all dark:border-gray-600 peer-checked:bg-red-600"></div>
                </label>
            </div>
        </div>
    </div>

    <div class="space-y-6">
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md p-6 sticky top-6">
            <h2 class="text-xl font-bold text-gray-800 dark:text-white mb-6">Actions</h2>
            <button id="saveServerLockSettings" class="w-full flex items-center justify-center px-4 py-3 bg-red-600 hover:bg-red-700 text-white font-bold rounded-xl transition-all duration-300 transform hover:scale-105 shadow-lg">
                <i class="fas fa-save mr-2"></i> Save Settings
            </button>
        </div>
    </div>
</div>

<script src="/js/serverlock.js"></script>
