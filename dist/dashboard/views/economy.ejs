<%- contentFor('body') %>

<div class="bg-gradient-to-r from-yellow-500 to-yellow-600 text-white rounded-xl shadow-lg mb-6 overflow-hidden animate-fade-in">
    <div class="relative p-6 md:p-8">
        <div class="absolute right-0 top-0 opacity-10">
            <i class="fas fa-coins fa-10x"></i>
        </div>
        <div class="relative z-10">
            <h1 class="text-2xl md:text-3xl lg:text-4xl font-bold mb-2">Economy Settings</h1>
            <p class="text-yellow-100 mb-4 max-w-2xl">
                Configure your server's currency, rewards, and success rates.
            </p>
        </div>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-2 space-y-6">
        <!-- Global Economy -->
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md p-6">
            <div class="flex items-center justify-between mb-6">
                <h2 class="text-xl font-bold text-gray-800 dark:text-white">Global Settings</h2>
                <label class="relative inline-flex items-center cursor-pointer">
                    <input type="checkbox" id="economyEnabled" class="sr-only peer" <%= settings.economy?.enabled ? 'checked' : '' %>>
                    <div class="w-14 h-7 bg-gray-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-yellow-300 dark:peer-focus:ring-yellow-800 rounded-full peer dark:bg-gray-700 peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-0.5 after:left-[4px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-6 after:w-6 after:transition-all dark:border-gray-600 peer-checked:bg-yellow-600"></div>
                </label>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 economy-controls <%= settings.economy?.enabled ? '' : 'opacity-50 pointer-events-none' %>">
                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Currency Symbol</label>
                    <input type="text" id="currencySymbol" value="<%= settings.economy?.currency || '💰' %>" class="w-full bg-gray-50 dark:bg-gray-700 border border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white text-sm rounded-lg p-2.5">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Daily Reward Amount</label>
                    <input type="number" id="dailyAmount" value="<%= settings.economy?.dailyAmount || 100 %>" class="w-full bg-gray-50 dark:bg-gray-700 border border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white text-sm rounded-lg p-2.5">
                </div>
            </div>
        </div>

        <!-- Work & Crime -->
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md p-6 economy-controls <%= settings.economy?.enabled ? '' : 'opacity-50 pointer-events-none' %>">
            <h2 class="text-xl font-bold text-gray-800 dark:text-white mb-6">Work & Crime</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="space-y-4">
                    <h3 class="font-bold text-gray-700 dark:text-gray-300">Work Rewards</h3>
                    <div class="flex items-center space-x-2">
                        <input type="number" id="workMin" value="<%= settings.economy?.workMin || 50 %>" class="w-full bg-gray-50 dark:bg-gray-700 border border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white text-sm rounded-lg p-2.5" placeholder="Min">
                        <span>-</span>
                        <input type="number" id="workMax" value="<%= settings.economy?.workMax || 150 %>" class="w-full bg-gray-50 dark:bg-gray-700 border border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white text-sm rounded-lg p-2.5" placeholder="Max">
                    </div>
                </div>
                <div class="space-y-4">
                    <h3 class="font-bold text-gray-700 dark:text-gray-300">Crime Success Rate (%)</h3>
                    <input type="number" id="crimeSuccessRate" value="<%= settings.economy?.crimeSuccessRate || 45 %>" min="1" max="100" class="w-full bg-gray-50 dark:bg-gray-700 border border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white text-sm rounded-lg p-2.5">
                </div>
            </div>
        </div>
    </div>

    <!-- Actions -->
    <div class="space-y-6">
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md p-6 sticky top-6">
            <h2 class="text-xl font-bold text-gray-800 dark:text-white mb-6">Actions</h2>
            <button id="saveEconomySettings" class="w-full flex items-center justify-center px-4 py-3 bg-yellow-600 hover:bg-yellow-700 text-white font-bold rounded-xl transition-all duration-300 transform hover:scale-105 shadow-lg">
                <i class="fas fa-save mr-2"></i> Save Settings
            </button>
        </div>
    </div>
</div>

<script src="/js/economy.js"></script>
