<%- contentFor('body') %>

<div class="bg-gradient-to-r from-teal-500 to-teal-700 text-white rounded-xl shadow-lg mb-6 overflow-hidden animate-fade-in">
    <div class="relative p-6 md:p-8">
        <div class="absolute right-0 top-0 opacity-10">
            <i class="fas fa-align-left fa-10x"></i>
        </div>
        <div class="relative z-10">
            <h1 class="text-2xl md:text-3xl lg:text-4xl font-bold mb-2"><%= locale.dashboard.navigation.autoLines %></h1>
            <p class="text-teal-100 mb-4 max-w-2xl">
                Schedule automatic messages to be sent to your channels on a regular basis.
            </p>
            
            <div class="flex flex-wrap gap-3 mt-4">
                <div class="flex items-center gap-2 bg-white/20 rounded-full px-4 py-1.5">
                    <div class="h-2.5 w-2.5 rounded-full <%= settings.autoLines?.enabled ? 'bg-green-400 animate-pulse' : 'bg-red-400' %>"></div>
                    <span class="text-sm font-medium"><%= settings.autoLines?.enabled ? 'Active' : 'Disabled' %></span>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Main Settings -->
    <div class="lg:col-span-2 space-y-6">
        <!-- System Control -->
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md p-6">
            <div class="flex items-center justify-between mb-6">
                <div>
                    <h2 class="text-xl font-bold text-gray-800 dark:text-white">System Status</h2>
                    <p class="text-sm text-gray-500 dark:text-gray-400">Enable or disable the auto lines system</p>
                </div>
                <label class="relative inline-flex items-center cursor-pointer">
                    <input type="checkbox" id="autoLinesEnabled" class="sr-only peer" <%= settings.autoLines?.enabled ? 'checked' : '' %>>
                    <div class="w-14 h-7 bg-gray-200 rounded-full peer dark:bg-gray-700 peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-0.5 after:left-[4px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-6 after:w-6 after:transition-all dark:border-gray-600 peer-checked:bg-teal-600"></div>
                </label>
            </div>
        </div>

        <!-- Channels -->
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md p-6 autolines-controls <%= settings.autoLines?.enabled ? '' : 'opacity-50 pointer-events-none' %>">
            <div class="flex items-center justify-between mb-6">
                <h2 class="text-xl font-bold text-gray-800 dark:text-white">Channel Schedules</h2>
                <button id="addAutoLineChannel" class="px-4 py-2 bg-teal-600 hover:bg-teal-700 text-white text-sm font-bold rounded-lg transition-colors">
                    <i class="fas fa-plus mr-2"></i> Add Channel
                </button>
            </div>

            <div id="autoLineChannelsList" class="space-y-6">
                <% (settings.autoLines?.channels || []).forEach((ch, index) => { %>
                    <div class="autoline-channel bg-gray-50 dark:bg-gray-700 p-4 rounded-xl border border-gray-200 dark:border-gray-600" data-index="<%= index %>">
                        <div class="flex items-center justify-between mb-4">
                            <div class="flex-1 mr-4">
                                <label class="block text-xs font-bold text-gray-500 dark:text-gray-400 uppercase mb-1">Target Channel</label>
                                <select class="channel-id w-full bg-white dark:bg-gray-800 border-none text-sm rounded-lg focus:ring-teal-500">
                                    <% channels.forEach(channel => { %>
                                        <option value="<%= channel.id %>" <%= ch.channelId === channel.id ? 'selected' : '' %>># <%= channel.name %></option>
                                    <% }) %>
                                </select>
                            </div>
                            <div class="w-24 mr-4">
                                <label class="block text-xs font-bold text-gray-500 dark:text-gray-400 uppercase mb-1">Interval (min)</label>
                                <input type="number" class="interval w-full bg-white dark:bg-gray-800 border-none text-sm rounded-lg focus:ring-teal-500" value="<%= ch.interval || 60 %>" min="1">
                            </div>
                            <button class="remove-autoline-channel text-red-500 hover:text-red-700 mt-5">
                                <i class="fas fa-trash"></i>
                            </button>
                        </div>
                        
                        <div>
                            <label class="block text-xs font-bold text-gray-500 dark:text-gray-400 uppercase mb-1">Messages (One per line)</label>
                            <textarea class="messages-list w-full bg-white dark:bg-gray-800 border-none text-sm rounded-lg focus:ring-teal-500" rows="3" placeholder="Enter messages here..."><%= (ch.messages || []).join('\n') %></textarea>
                            <p class="text-[10px] text-gray-500 mt-1">If multiple messages are provided, one will be chosen randomly.</p>
                        </div>
                    </div>
                <% }) %>
            </div>
        </div>
    </div>

    <!-- Actions -->
    <div class="space-y-6">
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md p-6 sticky top-6">
            <h2 class="text-xl font-bold text-gray-800 dark:text-white mb-6">Actions</h2>
            <div class="space-y-4">
                <button id="saveAutoLinesSettings" class="w-full flex items-center justify-center px-4 py-3 bg-teal-600 hover:bg-teal-700 text-white font-bold rounded-xl transition-all duration-300 transform hover:scale-105 shadow-lg">
                    <i class="fas fa-save mr-2"></i>
                    Save Settings
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    const availableChannels = <%- JSON.stringify(channels) %>;
</script>
<script src="/js/autoLines.js"></script>
