<%- contentFor('body') %>

<div class="bg-gradient-to-r from-green-500 to-green-600 text-white rounded-xl shadow-lg mb-6 overflow-hidden animate-fade-in">
    <div class="relative p-6 md:p-8">
        <div class="absolute right-0 top-0 opacity-10">
            <i class="fas fa-user-check fa-10x"></i>
        </div>
        <div class="relative z-10">
            <h1 class="text-2xl md:text-3xl lg:text-4xl font-bold mb-2">Verification Settings</h1>
            <p class="text-green-100 mb-4 max-w-2xl">
                Set up a verification system to prevent bots and unauthorized users.
            </p>
        </div>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-2 space-y-6">
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md p-6">
            <div class="flex items-center justify-between mb-6">
                <h2 class="text-xl font-bold text-gray-800 dark:text-white">System Status</h2>
                <label class="relative inline-flex items-center cursor-pointer">
                    <input type="checkbox" id="verificationEnabled" class="sr-only peer" <%= settings.verification?.enabled ? 'checked' : '' %>>
                    <div class="w-14 h-7 bg-gray-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-green-300 dark:peer-focus:ring-green-800 rounded-full peer dark:bg-gray-700 peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-0.5 after:left-[4px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-6 after:w-6 after:transition-all dark:border-gray-600 peer-checked:bg-green-600"></div>
                </label>
            </div>

            <div class="space-y-4 verification-controls <%= settings.verification?.enabled ? '' : 'opacity-50 pointer-events-none' %>">
                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Verification Role</label>
                    <select id="verificationRole" class="w-full bg-gray-50 dark:bg-gray-700 border border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white text-sm rounded-lg p-2.5">
                        <option value="">Select a role</option>
                        <% roles.forEach(role => { %>
                            <option value="<%= role.id %>" <%= settings.verification?.roleId === role.id ? 'selected' : '' %>>@ <%= role.name %></option>
                        <% }) %>
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Verification Message</label>
                    <textarea id="verificationMessage" rows="3" class="w-full bg-gray-50 dark:bg-gray-700 border border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white text-sm rounded-lg p-2.5"><%= settings.verification?.message || 'Click the button below to verify!' %></textarea>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Button Label</label>
                    <input type="text" id="verificationButtonLabel" value="<%= settings.verification?.buttonLabel || 'Verify Me' %>" class="w-full bg-gray-50 dark:bg-gray-700 border border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white text-sm rounded-lg p-2.5">
                </div>
            </div>
        </div>
    </div>

    <div class="space-y-6">
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md p-6 sticky top-6">
            <h2 class="text-xl font-bold text-gray-800 dark:text-white mb-6">Actions</h2>
            <button id="saveVerificationSettings" class="w-full flex items-center justify-center px-4 py-3 bg-green-600 hover:bg-green-700 text-white font-bold rounded-xl transition-all duration-300 transform hover:scale-105 shadow-lg">
                <i class="fas fa-save mr-2"></i> Save Settings
            </button>
        </div>
    </div>
</div>

<script src="/js/verification.js"></script>
